# Скопируйте этот файл в .env  (cp .env.example .env)  и заполните значения.
# Файл .env в git не попадает (см. .gitignore).

# === СЕРВЕР (server/proxy.mjs) ===
# Ключ API. Хранится только на сервере, во фронтенд-бандл не попадает.
# При использовании ProxyAPI — это ключ ProxyAPI (не ключ самого OpenAI).
OPENAI_API_KEY=
# Базовый URL OpenAI-совместимого API.
#   • прямой OpenAI:  https://api.openai.com/v1  (значение по умолчанию)
#   • ProxyAPI (РФ):  https://api.proxyapi.ru/openai/v1
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
# Порт сервера (необязательно, по умолчанию 8787).
PORT=8787

# === ФРОНТЕНД (Vite, только переменные с префиксом VITE_) ===
# Адрес ИИ-прокси. В проде уже задан в .env.production как /api/chat,
# здесь нужен ТОЛЬКО для локального теста настоящей модели:
#   VITE_AI_ENDPOINT=http://localhost:8787/api/chat
# Если оставить пустым — чат работает в демо-режиме (заглушка без ИИ).
VITE_AI_ENDPOINT=
